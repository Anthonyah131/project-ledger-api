{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "SecretKey": "${JWT_SECRET_KEY}",
    "Issuer": "ProjectLedger.API",
    "Audience": "ProjectLedger.Client",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Google": {
    "ClientId": "${GOOGLE_CLIENT_ID}",
    "ClientSecret": "${GOOGLE_CLIENT_SECRET}",
    "FrontendCallbackUrl": "https://project-ledger-web.vercel.app/auth/callback"
  },
  "Mcp": {
    "ServiceToken": "${MCP_SERVICE_TOKEN}"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://project-ledger-web.vercel.app"
    ]
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 0
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=avalom-cluster-15159.7tt.aws-us-east-1.cockroachlabs.cloud;Port=26257;Database=finance_dev;Username=anthony;Password=${DB_PASSWORD};SSL Mode=Require;Trust Server Certificate=true;Minimum Pool Size=2;Maximum Pool Size=20;Connection Idle Lifetime=300;Connection Pruning Interval=60;Keepalive=60;Timeout=15"
  },
  "EmailSettings": {
    "SmtpHost": "smtp.gmail.com",
    "SmtpPort": 587,
    "SmtpUser": "${GMAIL_USER}",
    "SmtpPassword": "${GMAIL_APP_PASSWORD}",
    "FromEmail": "${GMAIL_USER}",
    "FromName": "Project Ledger",
    "AdminEmail": "anthonyah131@gmail.com",
    "UseFakeProvider": false
  },
  "Stripe": {
    "Enabled": true,
    "SecretKey": "${STRIPE_SECRET_KEY}",
    "WebhookSecret": "${STRIPE_WEBHOOK_SECRET}",
    "SuccessUrl": "http://localhost:5173/billing/success",
    "CancelUrl": "http://localhost:5173/billing/cancel",
    "DefaultCurrency": "usd",
    "AllowPromotionCodes": true
  },
  "ExchangeRateApi": {
    "Enabled": true,
    "ApiKey": "${EXCHANGE_RATE_API_KEY}",
    "BaseUrl": "https://v6.exchangerate-api.com/",
    "TimeoutSeconds": 10
  },
  "AzureDocumentIntelligence": {
    "Enabled": false,
    "Endpoint": "${AZURE_DOC_INTELLIGENCE_ENDPOINT}",
    "ApiKey": "${AZURE_DOC_INTELLIGENCE_API_KEY}",
    "DefaultModelId": "prebuilt-receipt",
    "TimeoutSeconds": 30,
    "PollingIntervalMilliseconds": 1000,
    "MaxPollingAttempts": 30,
    "MaxFileSizeMb": 10
  },
  "Chatbot": {
    "SystemPrompt": "You are the Project Ledger AI assistant, a helpful financial assistant integrated into the Project Ledger accounting platform. Always respond in the same language the user writes in — if they write in Spanish, reply in Spanish; if they write in English, reply in English. Be concise, friendly, and professional. Focus on helping with financial topics such as expenses, income, budgets, reports, and accounting concepts.",
    "OpenRouter": {
      "Enabled": true,
      "ApiKey": "${CHATBOT_OPENROUTER_API_KEY}",
      "BaseUrl": "https://openrouter.ai/api/v1",
      "Model": "openrouter/free",
      "TimeoutSeconds": 30,
      "SupportsToolCalling": true
    },
    "Groq": {
      "Enabled": true,
      "ApiKey": "${CHATBOT_GROQ_API_KEY}",
      "BaseUrl": "https://api.groq.com/openai/v1",
      "Model": "meta-llama/llama-4-scout-17b-16e-instruct",
      "TimeoutSeconds": 30,
      "SupportsToolCalling": true
    },
    "Cerebras": {
      "Enabled": true,
      "ApiKey": "${CHATBOT_CEREBRAS_API_KEY}",
      "BaseUrl": "https://api.cerebras.ai/v1",
      "Model": "llama3.1-8b",
      "TimeoutSeconds": 30,
      "SupportsToolCalling": false
    },
    "BytePlus": {
      "Enabled": false,
      "ApiKey": "${CHATBOT_BYTEPLUS_API_KEY}",
      "BaseUrl": "https://ark.ap-southeast.bytepluses.com/api/v3",
      "Model": "doubao-lite-4k",
      "TimeoutSeconds": 30,
      "SupportsToolCalling": false
    }
  }
}